# OpenAI
OPENAI_API_KEY=sk-...

# Database (connection URL — used by both scraper and web)
DATABASE_URL=postgresql://user:password@your-rds-host.amazonaws.com:5432/hn_digest

# AWS S3
# Authentication is handled via IAM roles (ECS task role / Lambda execution role).
# No access keys needed — the AWS SDK uses the default credential chain.
AWS_REGION=us-east-1
S3_BUCKET_NAME=hn-digest

# Next.js
NEXT_PUBLIC_APP_URL=https://your-alb-dns.amazonaws.com
